# FastAPI application environment variables
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL connection string for SQLAlchemy / MySQL driver
DATABASE_URL=mysql+aiomysql://user:password@db:3306/userdb

# MySQL container configuration
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=userdb
MYSQL_USER=user
MYSQL_PASSWORD=change_me_password
